# Purplle Retail Intelligence production environment template
#
# Copy values into your deployment platform secret manager. Do not commit real
# secrets, database credentials, or production API keys.

ENV=prod
PORT=8080
APP_PUBLIC_BASE_URL=https://your-production-domain.example

# Persistence
DATABASE_URL=sqlite:///./store_intelligence.db
RESET_DB_ON_STARTUP=0

# Browser and host boundaries
ALLOWED_ORIGINS=https://your-production-domain.example
ALLOWED_HOSTS=your-production-domain.example
ENABLE_HSTS=1

# API protection
# When set, write/admin endpoints require X-API-Key or Authorization: Bearer.
API_KEY=replace-with-a-random-secret

# Traffic controls
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60
MAX_INGEST_BATCH=500
MAX_REQUEST_BODY_BYTES=5242880

# Pipeline
INGEST_URL=https://your-production-domain.example/events/ingest
STORE_ID=ST1008
STORE_CODE=store_1008
